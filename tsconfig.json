{
  "extends": "./.wxt/tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.vue",
    ".wxt/types/*.d.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "vite.config.ts",
    "tailwind.config.ts"
  ]
}
